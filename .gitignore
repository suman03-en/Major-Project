.venv
__pycache__
*.__pycache__

# Virtual environment
.venv/
.env

#ignore agents rules files
.ai/rules/*
.agents/*
.agents/rules/

#Ignore everything inside these folders
input_pdfs/*
output_jsons/*

# But don't ignore the .gitkeep files! 
# (The '!' means "except")
!input_pdfs/.gitkeep
!output_jsons/.gitkeep

# Python cache
__pycache__/
*.pyc
*.pyo

# IDE
.vscode/
.idea/

# OS files
Thumbs.db
.DS_Store

# Vector store (local dev artifacts)
vector_store/

# Scratch / test artifacts (development only)
scratch_*.py
test_ocr_*.py
test_ocr_*.txt
test_extractor.py
scratch_output.txt
REPORT_EMBEDDING.md